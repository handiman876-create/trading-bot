# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# 1. Create an API key at https://developer.tradestation.com (it gives you a
#    Client ID and Client Secret). Make sure the redirect URI below is
#    registered as an allowed redirect URL for that key.
# 2. Fill in TS_CLIENT_ID / TS_CLIENT_SECRET below.
# 3. Run `python3 auth_setup.py` once — it opens a browser, you log in/authorize,
#    and it writes TS_REFRESH_TOKEN back into this file automatically.

TS_CLIENT_ID=your_client_id_here
TS_CLIENT_SECRET=your_client_secret_here

# Filled in automatically by auth_setup.py — leave blank initially.
TS_REFRESH_TOKEN=

# true = paper-trading simulator (sim-api). Set to false for LIVE real-money trading.
TS_SANDBOX=true

# Optional: only override if you registered a different redirect URL for your key.
# TS_REDIRECT_URI=http://localhost:3000/
